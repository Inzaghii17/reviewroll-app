# ========================================
# ReviewRoll Environment Configuration
# ========================================
# Copy this to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=reviewroll
DB_PORT=3306
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# Optional: absolute path to CA certificate for managed MySQL
# DB_SSL_CA_PATH=C:\\path\\to\\ca.pem

JWT_SECRET=replace_me_with_a_long_random_secret
CORS_ORIGINS=http://localhost:3000

# TMDB Configuration (for movie metadata and legal watch providers)
TMDB_API_KEY=your_tmdb_api_key_here

# Streaming Configuration
# Community embed providers (vidsrc.to, vidsrc.me, etc.) are used for free streaming
# These are officially documented and widely used in the industry
# Ensure your ToS and privacy policy mention this feature
STREAMING_ENABLED=true
STREAMING_PRIMARY_PROVIDER=vidsrc
STREAMING_FALLBACK_PROVIDERS=vidsrc,vidsrcme,superembed,multiembed

# Optional: Admin Email for notifications
ADMIN_EMAIL=admin@example.com

# Optional: File upload limits (in MB)
MAX_UPLOAD_SIZE=50

# Optional: Session configuration
SESSION_SECRET=your_secret_key_change_in_production

# Production Hosting (Render, Vercel, etc.)
# Uncomment and set these when deploying
# LOG_LEVEL=info
# SENTRY_DSN=your_sentry_dsn_for_error_monitoring
